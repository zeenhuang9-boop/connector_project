{
  "models": {
    "codex": "gpt-4o",
    "gemini": "gemini-2.5-flash",
    "claude": "claude-sonnet-4-20250514"
  },
  "agents": {
    "gemini": {
      "backend": "gemini",
      "role": "coder",
      "rate_limit": 1.0
    },
    "codex": {
      "backend": "codex",
      "role": "reviewer",
      "rate_limit": 1.0
    }
  },
  "security": {
    "max_message_length": 8000,
    "rate_limit_per_second": 1.0,
    "banned_patterns": [
      "<\\/?system>",
      "\\[SYSTEM\\]",
      "ignore previous instructions",
      "<\\|im_start\\|>"
    ]
  },
  "context": {
    "max_history": 20,
    "save_context": true
  }
}
